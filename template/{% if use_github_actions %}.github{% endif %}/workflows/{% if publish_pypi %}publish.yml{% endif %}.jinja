{% raw %}# Reusable workflow: build and publish to PyPI via Trusted Publishing (OIDC).
# Called by release.yml after a successful release. No API token required.
# Configure the publisher at https://pypi.org/manage/account/publishing/
name: Publish

on:
  workflow_call:
    inputs:
      ref:
        description: "Git ref (tag) to build and publish"
        required: false
        type: string
        default: ""

jobs:
  publish:
    runs-on: ubuntu-latest
    environment: pypi
    permissions:
      id-token: write
      contents: read
    steps:
      - uses: actions/checkout@v4
        with:
          ref: ${{ inputs.ref }}
      - name: Install uv
        uses: astral-sh/setup-uv@v5
      - name: Build
        run: uv build
      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
{% endraw %}